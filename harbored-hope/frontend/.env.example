# ─── HOW TO USE ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values for your machine.
# .env.local is gitignored — never commit the real file.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL (no trailing slash)
# Default dev value works if you run the backend with default launch settings.
VITE_API_URL=http://localhost:5000
